---

<Layout title="Contagesti">
  <!-- <SeccionComercialContabilidad href="/contabilidad" /> -->
  <!-- <SeccionComercialCapacitaciones href="/capacitaciones" /> -->
  <!-- <Header /> -->
  <Headermejorado />
  <Hero imageSrc="/images/image-hero.png" />
  <AdvisoryCarousel client:load />
  <AccountingSolutionsSection />
  <TrainingSection
    client:load
    entrepreneurImageSrc="/images/image-contagesti-emprendedor.png"
    teamImageSrc="/images/image-contagesti-equipo.png"
  />
  <DigitalTransformationSection />
  <FAQSection client:load />
  <FooterPrincipal
    brandName="Contagesti"
    phone="+51 999 999 999"
    email="contacto@contagesti.com"
    address="Trujillo, Perú"
  />
  <!-- <SeccionComercialTransformacionDigital href="/transformacion-digital" /> -->
