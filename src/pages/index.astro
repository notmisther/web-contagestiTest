import SeccionComercialContabilidad from "../components/a reutilizar luego/SeccionComercialContabilidad";
import SeccionComercialCapacitaciones from "../components/a reutilizar luego/SeccionComercialCapacitaciones";
import SeccionComercialTransformacionDigital from "../components/a reutilizar luego/SeccionComercialTransformacionDigital";

import FooterPrincipal from "../components/a reutilizar luego/FooterPrincipal";
import Header from "../components/creados/Header.astro";
import Headermejorado from "../components/creados/Header-mejorado.astro";

//sections
import Hero from "../components/sections/Hero";
import AdvisoryCarousel from "../components/sections/AdvisoryCarousel";
import AccountingSolutionsSection from "../components/sections/AccountingSolutionsSection";
import TrainingSection from "../components/sections/TrainingSection";
