---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

import Headermejorado from "../components/creados/Header-mejorado.astro";
import FooterPrincipal from "../components/a reutilizar luego/FooterPrincipal";

interface Props {
  title?: string;
}

const { title = "Contagesti" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Headermejorado />
    <slot />
    <FooterPrincipal
      brandName="Contagesti"
      phone="+51 923 880 101"
      email="contacto@contagesti.com"
      address="Trujillo, Perú"
    />
  </body>
</html>
